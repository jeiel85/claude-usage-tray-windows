<Window x:Class="ClaudeUsageTray.Views.UsagePopup"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Claude Usage"
        Width="320"
        SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize">

    <Window.Resources>
        <SolidColorBrush x:Key="BgBrush" Color="#0F1117"/>
        <SolidColorBrush x:Key="CardBrush" Color="#1A1D2E"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#2D2F45"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#F1F5F9"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#8B92B3"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#8B5CF6"/>
        <SolidColorBrush x:Key="AccentLight" Color="#A78BFA"/>
        <SolidColorBrush x:Key="WarningBrush" Color="#F59E0B"/>
        <SolidColorBrush x:Key="DangerBrush" Color="#EF4444"/>
        <SolidColorBrush x:Key="SuccessBrush" Color="#10B981"/>

        <Style x:Key="UsageBarStyle" TargetType="ProgressBar">
            <Setter Property="Height" Value="6"/>
            <Setter Property="Background" Value="#2D2F45"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid>
                            <Border Background="{TemplateBinding Background}" CornerRadius="3"/>
                            <Border x:Name="PART_Track" CornerRadius="3"/>
                            <Border x:Name="PART_Indicator" HorizontalAlignment="Left" CornerRadius="3">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#8B5CF6" Offset="0"/>
                                        <GradientStop Color="#6366F1" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Value" Value="0">
                                <Setter TargetName="PART_Indicator" Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#8B92B3"/>
        </Style>
    </Window.Resources>

    <Border Margin="8">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.5" Color="#000000"/>
        </Border.Effect>

        <Border Background="{StaticResource BgBrush}"
                CornerRadius="16"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1">
            <StackPanel>

                <!-- Header -->
                <Border Background="#1A1D2E" CornerRadius="16,16,0,0" Padding="16,14,16,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="28" Height="28" CornerRadius="8" Margin="0,0,10,0">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#8B5CF6" Offset="0"/>
                                        <GradientStop Color="#6366F1" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock Text="C" Foreground="White" FontWeight="Bold"
                                           FontSize="14" HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{Binding LblAppTitle}" Foreground="#F1F5F9"
                                           FontSize="14" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding LastUpdatedLabel}"
                                           Foreground="#8B92B3" FontSize="11"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Refresh button -->
                        <Button Grid.Column="1" x:Name="RefreshBtn"
                                Width="32" Height="32"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand"
                                ToolTip="{Binding LblRefresh}"
                                Click="RefreshBtn_Click">
                            <TextBlock Text="↻" Foreground="#8B92B3" FontSize="16"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#2D2F45"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                </Border>

                <!-- Loading indicator -->
                <Border Padding="16,8" Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="⟳ " Foreground="#8B5CF6" FontSize="12"/>
                        <TextBlock Text="{Binding LblRefreshing}" Foreground="#8B92B3" FontSize="12"/>
                    </StackPanel>
                </Border>

                <!-- Error panel -->
                <Border Padding="12,10" Margin="16,4"
                        Background="#2D1515" CornerRadius="8"
                        Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="#EF4444"
                               FontSize="11" TextWrapping="Wrap"/>
                </Border>

                <!-- API Usage section -->
                <StackPanel Margin="16,12,16,0">
                    <TextBlock Style="{StaticResource SectionLabel}" Text="{Binding LblApiQuota}" Margin="0,0,0,10"/>

                    <!-- 5-hour window -->
                    <Grid Margin="0,0,0,12">
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition Height="8"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding LblFiveHour}"
                                       Foreground="#C4C9E0" FontSize="12" FontWeight="Medium"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <TextBlock Text="{Binding ShortUsagePercent, StringFormat={}{0:P0}}"
                                           Foreground="#A78BFA" FontSize="12" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding ShortResetLabel}"
                                           Foreground="#8B92B3" FontSize="11"/>
                            </StackPanel>
                        </Grid>
                        <ProgressBar Grid.Row="1"
                                     Value="{Binding ShortUsagePercent}"
                                     Maximum="1"
                                     Style="{StaticResource UsageBarStyle}"
                                     Margin="0,6,0,0"/>
                    </Grid>

                    <!-- 7-day window -->
                    <Grid Margin="0,0,0,8">
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition Height="8"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding LblSevenDay}"
                                       Foreground="#C4C9E0" FontSize="12" FontWeight="Medium"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <TextBlock Text="{Binding LongUsagePercent, StringFormat={}{0:P0}}"
                                           Foreground="#A78BFA" FontSize="12" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding LongResetLabel}"
                                           Foreground="#8B92B3" FontSize="11"/>
                            </StackPanel>
                        </Grid>
                        <ProgressBar Grid.Row="1"
                                     Value="{Binding LongUsagePercent}"
                                     Maximum="1"
                                     Style="{StaticResource UsageBarStyle}"
                                     Margin="0,6,0,0"/>
                    </Grid>
                </StackPanel>

                <!-- Divider -->
                <Border Height="1" Background="#2D2F45" Margin="16,12"/>

                <!-- Today's token usage -->
                <StackPanel Margin="16,0,16,0">
                    <TextBlock Style="{StaticResource SectionLabel}" Text="{Binding LblTodayTokens}" Margin="0,0,0,10"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Input -->
                        <Border Grid.Column="0" Background="#1A1D2E" CornerRadius="10" Padding="12,10" Margin="0,0,6,0">
                            <StackPanel>
                                <TextBlock Text="{Binding LblInput}" Foreground="#8B92B3" FontSize="10"
                                           FontWeight="SemiBold" Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding TodayInputTokens, StringFormat={}{0:N0}}"
                                           Foreground="#A78BFA" FontSize="15" FontWeight="Bold"/>
                                <TextBlock Text="{Binding LblTokens}" Foreground="#8B92B3" FontSize="10"/>
                            </StackPanel>
                        </Border>

                        <!-- Output -->
                        <Border Grid.Column="1" Background="#1A1D2E" CornerRadius="10" Padding="12,10" Margin="6,0,0,0">
                            <StackPanel>
                                <TextBlock Text="{Binding LblOutput}" Foreground="#8B92B3" FontSize="10"
                                           FontWeight="SemiBold" Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding TodayOutputTokens, StringFormat={}{0:N0}}"
                                           Foreground="#6EE7B7" FontSize="15" FontWeight="Bold"/>
                                <TextBlock Text="{Binding LblTokens}" Foreground="#8B92B3" FontSize="10"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Cache -->
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="#1A1D2E" CornerRadius="10" Padding="12,8" Margin="0,0,6,0">
                            <StackPanel>
                                <TextBlock Text="{Binding LblCacheRead}" Foreground="#8B92B3" FontSize="10"
                                           FontWeight="SemiBold" Margin="0,0,0,2"/>
                                <TextBlock Text="{Binding TodayCacheRead, StringFormat={}{0:N0}}"
                                           Foreground="#93C5FD" FontSize="13" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Background="#1A1D2E" CornerRadius="10" Padding="12,8" Margin="6,0,0,0">
                            <StackPanel>
                                <TextBlock Text="{Binding LblCacheWrite}" Foreground="#8B92B3" FontSize="10"
                                           FontWeight="SemiBold" Margin="0,0,0,2"/>
                                <TextBlock Text="{Binding TodayCacheWrite, StringFormat={}{0:N0}}"
                                           Foreground="#FCA5A5" FontSize="13" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>

                <!-- Rate limit warning -->
                <Border Visibility="{Binding HasRateLimitHit, Converter={StaticResource BoolToVisibility}}"
                        Margin="16,10,16,0" Background="#1F1A0A" CornerRadius="10"
                        Padding="12,10" BorderBrush="#F59E0B" BorderThickness="1">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⚠ " Foreground="#F59E0B" FontSize="12"/>
                        <TextBlock Text="{Binding RateLimitInfo}" Foreground="#FCD34D"
                                   FontSize="11" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- Notification Settings Panel -->
                <Border Margin="16,0,16,0" CornerRadius="10" Background="#1A1D2E"
                        Visibility="{Binding SettingsOpen, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel Margin="14,12">
                        <TextBlock Text="{Binding LblNotifications}" Style="{StaticResource SectionLabel}" Margin="0,0,0,10"/>

                        <!-- Enable toggle -->
                        <CheckBox Content="{Binding LblNotiEnabled}" IsChecked="{Binding NotificationsEnabled}"
                                  Foreground="#C4C9E0" FontSize="12" Margin="0,0,0,6"
                                  Command="{Binding SaveSettingsCommand}"/>

                        <!-- Rate limit -->
                        <CheckBox Content="{Binding LblNotiRateLimit}" IsChecked="{Binding NotifyRateLimit}"
                                  Foreground="#C4C9E0" FontSize="12" Margin="0,0,0,10"
                                  IsEnabled="{Binding NotificationsEnabled}"
                                  Command="{Binding SaveSettingsCommand}"/>

                        <!-- Thresholds -->
                        <TextBlock Text="{Binding LblThresholds}" Foreground="#8B92B3" FontSize="10"
                                   FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <WrapPanel>
                            <CheckBox Content="50%" IsChecked="{Binding Threshold50}"
                                      Foreground="#C4C9E0" FontSize="12" Margin="0,0,12,4"
                                      IsEnabled="{Binding NotificationsEnabled}"
                                      Command="{Binding SaveSettingsCommand}"/>
                            <CheckBox Content="75%" IsChecked="{Binding Threshold75}"
                                      Foreground="#C4C9E0" FontSize="12" Margin="0,0,12,4"
                                      IsEnabled="{Binding NotificationsEnabled}"
                                      Command="{Binding SaveSettingsCommand}"/>
                            <CheckBox Content="90%" IsChecked="{Binding Threshold90}"
                                      Foreground="#C4C9E0" FontSize="12" Margin="0,0,12,4"
                                      IsEnabled="{Binding NotificationsEnabled}"
                                      Command="{Binding SaveSettingsCommand}"/>
                            <CheckBox Content="100%" IsChecked="{Binding Threshold100}"
                                      Foreground="#C4C9E0" FontSize="12" Margin="0,0,0,4"
                                      IsEnabled="{Binding NotificationsEnabled}"
                                      Command="{Binding SaveSettingsCommand}"/>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <!-- Footer -->
                <Border Padding="16,10" Margin="0,6,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding SessionsLabel}"
                                   Foreground="#8B92B3" FontSize="11" VerticalAlignment="Center"/>

                        <!-- Settings gear button -->
                        <Button Grid.Column="1" Width="28" Height="28" Margin="0,0,4,0"
                                Background="Transparent" BorderThickness="0" Cursor="Hand"
                                ToolTip="{Binding LblNotifications}"
                                Click="SettingsBtn_Click">
                            <TextBlock Text="⚙" FontSize="13" VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#8B92B3"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SettingsOpen}" Value="True">
                                                <Setter Property="Foreground" Value="#A78BFA"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#2D2F45"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button Grid.Column="2" x:Name="QuitBtn"
                                Content="{Binding LblQuit}"
                                Background="Transparent" BorderThickness="0"
                                Foreground="#8B92B3" FontSize="11" Cursor="Hand"
                                Click="QuitBtn_Click">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" Padding="6,3" CornerRadius="5">
                                                    <ContentPresenter/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#2D2F45"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                </Border>

            </StackPanel>
        </Border>
    </Border>

</Window>
