<Window x:Class="ClaudeUsageTray.Views.UpdateDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="업데이트 사용 가능"
        Width="360"
        SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize">

    <Border Margin="8">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.5" Color="#000000"/>
        </Border.Effect>

        <Border Background="#0F1117" CornerRadius="16"
                BorderBrush="#2D2F45" BorderThickness="1">
            <StackPanel>

                <!-- Header -->
                <Border Background="#1A1D2E" CornerRadius="16,16,0,0" Padding="16,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="28" Height="28" CornerRadius="8" Margin="0,0,10,0">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#8B5CF6" Offset="0"/>
                                        <GradientStop Color="#6366F1" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock Text="↑" Foreground="White" FontWeight="Bold"
                                           FontSize="14" HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock x:Name="DialogTitleLabel" Foreground="#F1F5F9"
                                           FontSize="14" FontWeight="SemiBold"/>
                                <TextBlock x:Name="VersionLabel" Foreground="#8B5CF6"
                                           FontSize="11" FontWeight="Medium"/>
                            </StackPanel>
                        </StackPanel>

                        <Button Grid.Column="1" x:Name="LaterBtn"
                                Width="32" Height="32"
                                Background="Transparent" BorderThickness="0"
                                Cursor="Hand" ToolTip="나중에"
                                Click="LaterBtn_Click">
                            <TextBlock Text="✕" Foreground="#3D4266" FontSize="13"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#2D2F45"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                </Border>

                <!-- Release notes -->
                <StackPanel Margin="16,14,16,0">
                    <TextBlock x:Name="WhatsNewLabel" Foreground="#8B92B3"
                               FontSize="10" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <Border Background="#1A1D2E" CornerRadius="10" Padding="12">
                        <ScrollViewer MaxHeight="220" VerticalScrollBarVisibility="Auto">
                            <TextBlock x:Name="ReleaseNotesText"
                                       Foreground="#C4C9E0" FontSize="12"
                                       TextWrapping="Wrap" LineHeight="20"
                                       FontFamily="Segoe UI"/>
                        </ScrollViewer>
                    </Border>
                </StackPanel>

                <!-- Buttons -->
                <StackPanel Margin="16,14,16,16">
                    <!-- Update button -->
                    <Button x:Name="UpdateBtn"
                            Height="38" Cursor="Hand"
                            BorderThickness="0"
                            Click="UpdateBtn_Click"
                            Margin="0,0,0,8">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border CornerRadius="10">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                        <GradientStop Color="#8B5CF6" Offset="0"/>
                                                        <GradientStop Color="#6366F1" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Opacity" Value="0.85"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="↑  " Foreground="White" FontSize="13" FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                            <TextBlock x:Name="UpdateNowLabel" Foreground="White" FontSize="13" FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Skip / Later row -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Skip this version -->
                        <Button Grid.Column="0" x:Name="SkipBtn"
                                Height="34" Cursor="Hand"
                                BorderThickness="1"
                                Click="SkipBtn_Click">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="#1A1D2E" CornerRadius="8"
                                                        BorderBrush="#3D4266" BorderThickness="1">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Opacity" Value="0.75"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                            <TextBlock x:Name="SkipLabel" Foreground="#8B92B3"
                                       FontSize="11" VerticalAlignment="Center"/>
                        </Button>

                        <!-- Later -->
                        <Button Grid.Column="2" x:Name="LaterBtn2"
                                Height="34" Cursor="Hand"
                                BorderThickness="0"
                                Click="LaterBtn_Click">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="#1A1D2E" CornerRadius="8"
                                                        BorderBrush="#3D4266" BorderThickness="1">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Opacity" Value="0.75"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                            <TextBlock x:Name="LaterLabel" Foreground="#8B92B3"
                                       FontSize="11" VerticalAlignment="Center"/>
                        </Button>
                    </Grid>
                </StackPanel>

            </StackPanel>
        </Border>
    </Border>
</Window>
